{
  "name": "your-gut-healed",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development node scripts/start-dev.mjs",
    "build": "pnpm build:client && pnpm build:server && pnpm visual-qa",
    "build:client": "vite build --outDir dist/client --ssrManifest",
    "build:server": "node scripts/build-server.mjs",
    "visual-qa": "node scripts/visual-qa.mjs",
    "start": "NODE_ENV=production node scripts/start-with-cron.mjs",
    "verify-build": "NODE_ENV=production node -e \"import('./dist/index.js').then(()=>{console.log('import-ok');process.exit(0)}).catch(e=>{console.error(e);process.exit(1)})\"",
    "seed": "node scripts/seed-articles.mjs",
    "audit": "node scripts/audit-quality.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "compression": "^1.7.4",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "pg": "^8.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "serve-static": "^1.16.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
